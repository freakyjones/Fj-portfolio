# Treat all files as text and normalize line endings to LF on commit
* text=auto

# Explicitly declare files that should always use LF (line feed)
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.md text eol=lf

# Denote files that are binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.pdf binary
*.ico binary
